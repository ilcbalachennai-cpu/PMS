{
  "name": "bharatpay-pro",
  "private": true,
  "version": "02.02.33",
  "author": "ILCBala",
  "description": "BharatPay Pro - Indian Payroll Management System",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "dev:electron": "concurrently \"npm run dev\" \"npm run electron:serve\"",
    "electron:serve": "wait-on tcp:3000 && node electron/check-version.cjs && npx tsc -p electron/tsconfig.json && node -e \"const fs=require('fs'); if(!fs.existsSync('dist-electron')) fs.mkdirSync('dist-electron'); fs.writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}), 'utf8')\" && cross-env NODE_ENV=development electron .",
    "build:electron": "npm run build && node electron/build.cjs && electron-builder",
    "build:win10": "npm install electron@31.0.0 electron-builder@24.13.3 @types/node@22.14.0 --no-save && npm run build && node electron/build.cjs && electron-builder --config.nsis.artifactName=BPP_APP_V02.02.33_Win10.exe && npm run build:restore",
    "build:win7": "npm install electron@22.3.27 electron-builder@23.6.0 @types/node@18.11.18 better-sqlite3@9.6.0 && npm run build && node electron/build.cjs && electron-builder --config.nsis.artifactName=BPP_APP_V02.02.33_Win7.exe && npm run build:restore",
    "build:all": "npm run build:win10 && npm run build:win7 && npm run build:restore",
    "build:restore": "npm install electron@31.0.0 electron-builder@24.13.3 @types/node@22.14.0 better-sqlite3@^11.5.0",
    "generate:exe": "node scripts/build_all.cjs",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.ilcbala.bharatpaypro",
    "productName": "BharatPay Pro",
    "copyright": "Copyright © 2026 ILCBala",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.png",
      "publisherName": "ILCBala",
      "target": [
        "nsis"
      ],
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "shortcutName": "BharatPay Pro",
      "artifactName": "BPP_APP_V02.02.33_Win10.exe"
    },
    "files": [
      "dist",
      "dist-electron",
      "docs",
      "package.json"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "@types/nodemailer": "^7.0.11",
    "better-sqlite3": "^11.5.0",
    "bytenode": "^1.5.7",
    "crypto-js": "4.2.0",
    "date-fns": "^4.1.0",
    "follow-redirects": "^1.15.11",
    "fs-extra": "^11.2.0",
    "jspdf": "2.5.1",
    "jspdf-autotable": "3.8.2",
    "lucide-react": "^0.562.0",
    "nodemailer": "^8.0.4",
    "puppeteer": "^24.37.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-is": "^19.2.4",
    "recharts": "^3.6.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "inquirer": "^13.3.2",
    "javascript-obfuscator": "^5.3.0",
    "postcss": "^8.5.6",
    "rollup-plugin-javascript-obfuscator": "^1.0.4",
    "tailwindcss": "^4.2.1",
    "tmp": "^0.2.5",
    "typescript": "~5.8.2",
    "undici": "^8.0.1",
    "vite": "^6.2.0",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "validator": "13.15.35"
  }
}
